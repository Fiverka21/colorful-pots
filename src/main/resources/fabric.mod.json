{
	"schemaVersion": 1,
	"id": "colorful_pots",
	"version": "${version}",
	"name": "Colorful Pots",
	"description": "A starter Fabric mod scaffold for Colorful Pots.",
	"authors": [
		"fiverka"
	],
	"contact": {},
	"license": "MIT",
	"icon": "assets/colorful_pots/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"com.fiverka.colorfulpots.ColorfulPotsMod"
		],
		"client": [
			"com.fiverka.colorfulpots.client.ColorfulPotsModClient"
		]
	},
	"mixins": [
		"colorful_pots.mixins.json",
		{
			"config": "colorful_pots.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.19.2",
		"minecraft": "~1.21.11",
		"java": ">=21",
		"fabric-api": "*"
	}
}
